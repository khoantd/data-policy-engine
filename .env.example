# DRPE environment variables (never commit real secrets)

# Optional API key — when set, require Authorization: Bearer <key>
DRPE_API_KEY=

# Directory of YAML policy files loaded at startup
DRPE_POLICIES_DIR=config

# Force auth even if key empty (normally leave false)
DRPE_REQUIRE_AUTH=false

# Comma-separated browser origins for CORS (optional; Admin UI uses a Next.js BFF)
# DRPE_CORS_ORIGINS=http://localhost:3000

# Postgres (Supabase) — when set, use SqlAlchemyPolicyStore instead of in-memory.
# Prefer the Session pooler URI from the Supabase dashboard (Connect → Session mode).
# Pooler host may be aws-0-*, aws-1-*, etc. — copy the exact host from the dashboard
# (wrong cluster returns: FATAL tenant/user ... not found).
# Example (session pooler):
# DATABASE_URL=postgresql+psycopg://postgres.[ref]:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
# Example (direct — often IPv6-only):
# DATABASE_URL=postgresql+psycopg://postgres:[YOUR-PASSWORD]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=

# When true, re-seed YAML into DB even if policies already exist (skips newer versions)
DRPE_SEED_YAML=false

# Optional Redis — when set, wrap PolicyStore with CachingPolicyStore (get/list cache).
# REDIS_URL=redis://localhost:6379/0
# DRPE_REDIS_TTL_SECONDS=300
# DRPE_REDIS_KEY_PREFIX=drpe
# Cap Redis sockets per API process (default 20). Keep
# (API workers × this) + (Celery processes × broker pool) under Redis maxclients.
# DRPE_REDIS_MAX_CONNECTIONS=20

# Celery broker (defaults to REDIS_URL). Without a broker, tasks run eager in-process.
# CELERY_BROKER_URL=redis://localhost:6379/0
# Cap Celery broker pool per worker/beat/API process (default 10).
# DRPE_CELERY_BROKER_POOL_LIMIT=10
# Scan interval for Celery beat (seconds)
# DRPE_ENFORCE_INTERVAL_SECONDS=3600
# Optional HTTP webhook for dispatched enforcement actions
# DRPE_WEBHOOK_URL=https://hooks.example.com/drpe
# Force eager Celery (tests / single-process)
# DRPE_CELERY_EAGER=false
